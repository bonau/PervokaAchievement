<div class="achievement_entry <%= unlocked ? 'unlocked' : 'unlockable' %>">
  <% klass = achievement.is_a?(Class) ? achievement : achievement.class %>
  <% if unlocked %>
    <span class="date"><%= format_time(achievement.created_at) %></span>
  <% end %>
  <div class="achievement_icon_wrap">
    <%= achievement_icon(achievement, size: 48) %>
  </div>
  <div class="achievement_info">
    <h3><%= achievement_text(achievement, :title) %><%= image_tag('true.png') if unlocked %></h3>
    <h4><%= achievement_text(achievement, :description) %></h4>
    <p>&quot;<%= achievement_text(achievement, :quote) %>&quot;</p>
    <span class="achievement_tier tier_<%= klass.tier %>"><%= l(:"achievement.tier.#{klass.tier}") %></span>
    <span class="achievement_points"><%= klass.effective_points %> <%= l(:'achievement.points_unit') %></span>
    <% if klass.tags.any? %>
      <span class="achievement_tags">
        <% klass.tags.each do |tag| %>
          <span class="achievement_tag tag_<%= tag %>"><%= l(:"achievement.tag.#{tag}") %></span>
        <% end %>
      </span>
    <% end %>
  </div>
</div>
