# PostgreSQL 設定
POSTGRES_DB=redmine
POSTGRES_USER=redmine
POSTGRES_PASSWORD=redmine_password

# Redmine 設定
REDMINE_LANG=zh-TW

# 密鑰（生產環境務必更換！）
# 可以使用以下指令生成：
# docker run --rm redmine:5.1 bundle exec rake secret
REDMINE_SECRET_KEY_BASE=please_change_this_secret_key_in_production

# 埠號設定
REDMINE_PORT=3000
